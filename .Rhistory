title    = "La vs. Yb: REE Fractionation Trend",
subtitle = "LREE enrichment relative to HREE",
x = "Yb (ppm)", y = "La (ppm)",
colour = "Formation", shape = "Formation"
) +
theme_bw(base_size = 12) +
theme(legend.position = "bottom")
print(la_yb_plot)
ggsave("la_yb_diagram.png", la_yb_plot, width = 9, height = 5, dpi = 300)
#-----------------------------
# Plot Theme for Prim Mantle
#-----------------------------
geochem_theme <- function() {
theme_minimal(base_size = 13) +
theme(
legend.position = "none",
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
axis.text.x = element_text(
angle = 45,
hjust = 1,
face = "bold",
size = 11
),
axis.text.y = element_text(size = 11),
axis.title = element_text(face = "bold"),
plot.title = element_text(
size = 16,
face = "bold",
hjust = 0.5
)
)
}
#-----------------------------
# Plot Function for Prim Mantle
#-----------------------------
plot_geochem <- function(df, title, y_label) {
df %>%
prepare_geochem() %>%
ggplot(aes(Elements, Concentration, group = Sample, color = Sample)) +
geom_line(linewidth = 1.1, alpha = 0.85) +
geom_point(size = 2, alpha = 0.9) +
scale_y_log10(
breaks = c(10, 100, 1000),      # show exactly these ticks
labels = c("10", "100", "1000"), # labels exactly
limits = c(0.5, 1000)
)+
scale_color_viridis_d(option = "turbo") +
labs(
title = title,
x = "Trace Elements",
y = y_label
) +
geochem_theme()
}
#-----------------------------
# Generate Plots
#-----------------------------
plot_nmorb <- plot_geochem(
datasets$nmorb,
"N-MORB Normalized Trace Element Spider Diagram",
"Sample / N-MORB"
)
plot_prim <- plot_geochem(
datasets$prim_mantle,
"Primitive Mantle Normalized Trace Element Spider Diagram",
"Sample / Primitive Mantle"
)
# Display
plot_nmorb
plot_prim
ggsave("N-MORB_Spider.jpeg", plot = plot_nmorb, width = 10, height = 6, dpi = 300)
ggsave("PrimitiveMantle_Spider.jpeg", plot = plot_prim, width = 10, height = 6, dpi = 300)
