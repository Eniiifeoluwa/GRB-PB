rm(list=ls())
library(tidyverse)
library(ggplot2)
library(FactoMineR)   # PCA
library(factoextra)   # PCA visualisation
library(ICSNP)        # Hotelling's T² test
library(ggrepel)
library(patchwork)
library(scales)
library(readxl)
library(gridExtra)
grb <- read.csv("GRB ICP-MS.csv", stringsAsFactors = FALSE)
PB <- read.csv("PB ICP-MS.csv", stringsAsFactors = FALSE)
datasets <- list(
nmorb = read_excel("NMORB.xlsx"),
prim_mantle = read_excel("Prim Mantle.xlsx")) # DATA FOR VISUALIZING THEN PRIM MANTLE NORMALIZED
#-----------------------------
# Data Preparation for Prim Mantle
#-----------------------------
prepare_geochem <- function(df) {
df %>%
pivot_longer(
-Elements,
names_to = "Sample",
values_to = "Concentration"
) %>%
mutate(
Elements = factor(Elements, levels = unique(df$Elements))
)
}
#-----------------------------
# Data Preparation for Trace Elements
#-----------------------------
# Add a group label
grb$Group <- "GRB"
PB$Group <- "PB"
# Combine into one dataframe
df <- bind_rows(grb, PB)
df$Group <- factor(df$Group, levels = c("GRB", "PB"))
cat("=== Data dimensions ===\n")
cat("GRB:", nrow(grb), "samples |  PB:", nrow(PB), "samples\n\n")
cat("=== Column names ===\n")
print(colnames(df))
df <- df %>%
mutate(
La_Yb  = La  / Yb,          # Proxy for degree of partial melting
Eu_anom = Eu / (sqrt(Sm * Gd)),  # Eu anomaly (Eu*)
Sc_Zr  = Sc  / Zr,          # Cpx + plagioclase fractionation proxy
Ba_Nb  = Ba  / Nb,          # LILE/HFSE — crustal assimilation proxy
La_Nb  = La  / Nb           # Additional LILE/HFSE ratio
)
cat("\n=== Summary of diagnostic ratios ===\n")
df %>%
group_by(Group) %>%
summarise(
across(c(La_Yb, Eu_anom, Sc_Zr, Ba_Nb, La_Nb),
list(mean = ~mean(.x, na.rm = TRUE),
sd   = ~sd(.x,   na.rm = TRUE)),
.names = "{.col}_{.fn}")
) %>%
print(width = Inf)
ratios   <- c("La_Yb", "Eu_anom", "Sc_Zr", "Ba_Nb", "La_Nb")
alpha    <- 0.05
n_tests  <- length(ratios)
alpha_bc <- alpha / n_tests   # Bonferroni-corrected threshold
cat("\n=== Univariate Tests (Bonferroni α =", round(alpha_bc, 4), ") ===\n")
results_uni <- map_dfr(ratios, function(r) {
x <- df %>% filter(Group == "GRB") %>% pull(!!sym(r)) %>% na.omit()
y <- df %>% filter(Group == "PB") %>% pull(!!sym(r)) %>% na.omit()
# Shapiro-Wilk (only valid for n < 50)
sw_x <- if (length(x) >= 3) shapiro.test(x)$p.value else NA
sw_y <- if (length(y) >= 3) shapiro.test(y)$p.value else NA
normal <- !is.na(sw_x) & !is.na(sw_y) & sw_x > 0.05 & sw_y > 0.05
if (normal) {
test_res <- t.test(x, y, var.equal = FALSE)  # Welch t-test
test_name <- "Welch t-test"
} else {
test_res <- wilcox.test(x, y, exact = FALSE)  # Mann-Whitney U
test_name <- "Mann-Whitney U"
}
tibble(
Ratio      = r,
Test       = test_name,
Statistic  = round(test_res$statistic, 3),
p_value    = round(test_res$p.value, 4),
Sig_Bonf   = ifelse(test_res$p.value < alpha_bc, "***", "ns"),
GRB_mean   = round(mean(x), 3),
PB_mean   = round(mean(y), 3)
)
})
print(results_uni)
# =============================================================================
# 4. HOTELLING'S T² TEST (Multivariate)
# =============================================================================
# Select trace elements common to both groups for the multivariate test
trace_elements <- c("La", "Ce", "Pr", "Nd", "Sm", "Eu", "Gd",
"Tb", "Dy", "Ho", "Er", "Tm", "Yb", "Lu",
"Ba", "Th", "Nb", "Y", "Hf", "Ta", "U",
"Pb", "Rb", "Cs", "Sr", "Sc", "Zr")
# Keep only columns that actually exist
trace_elements <- intersect(trace_elements, colnames(df))
cat("\n=== Elements used in Hotelling's T² ===\n")
print(trace_elements)
# Log-transform and centre
df_trace <- df %>%
select(Group, all_of(trace_elements)) %>%
drop_na()
mat <- df_trace %>%
select(-Group) %>%
mutate(across(everything(), ~log(.x + 1e-9))) %>%  # log-transform
as.matrix()
grp <- df_trace$Group
HotellingsT2(mat[grp == "PB", ], mat[grp == "GRB", ])  %>%
{ cat("\n=== Hotelling's T² Result ===\n"); print(.) }
pca_data <- df %>%
select(Group, all_of(trace_elements)) %>%
drop_na() %>%
mutate(across(all_of(trace_elements), ~log(.x + 1e-9)))
pca_mat  <- pca_data %>% select(-Group)
pca_grp  <- pca_data$Group
pca_res  <- PCA(pca_mat, scale.unit = TRUE, graph = FALSE) #PCA result
cat("\n=== PCA Variance Explained ===\n")
print(get_eigenvalue(pca_res)[1:5, ])
# --- PCA Biplot -------------------------------------------------------------
ind_coords <- as.data.frame(pca_res$ind$coord[, 1:2])
ind_coords$Group <- pca_grp
var_coords <- as.data.frame(pca_res$var$coord[, 1:2])
var_coords$Element <- rownames(var_coords)
var_explained <- round(get_eigenvalue(pca_res)[1:2, "variance.percent"], 1)
pca_plot <- ggplot(ind_coords, aes(x = Dim.1, y = Dim.2, colour = Group, shape = Group)) +
geom_point(size = 3, alpha = 0.85) +
geom_hline(yintercept = 0, linetype = "dashed", colour = "grey60") +
geom_vline(xintercept = 0, linetype = "dashed", colour = "grey60") +
stat_ellipse(aes(group = Group), type = "norm", level = 0.90, linetype = "solid", linewidth = 0.7)+
scale_colour_manual(values = c("GRB" = "#2166ac", "PB" = "#d6604d")) +
scale_shape_manual(values  = c("GRB" = 16, "PB" = 17)) +
labs(
title    = "PCA of ICP-MS Trace Elements",
subtitle = "Log-transformed, centred & scaled | 90% confidence ellipses",
x        = paste0("PC1 (", var_explained[1], "% variance)"),
y        = paste0("PC2 (", var_explained[2], "% variance)"),
colour   = "Formation", shape = "Formation"
) +
theme_bw(base_size = 12) +
theme(legend.position = "bottom")
ggsave("pca_plot.png", pca_plot, width = 9, height = 5, dpi = 300)
print(pca_plot)
pca_plot <- ggplot(ind_coords, aes(x = Dim.1, y = Dim.2, colour = Group, shape = Group)) +
geom_point(size = 3, alpha = 0.85) +
geom_hline(yintercept = 0, linetype = "dashed", colour = "grey60") +
geom_vline(xintercept = 0, linetype = "dashed", colour = "grey60") +
stat_ellipse(aes(group = Group), type = "norm", level = 0.10, linetype = "solid", linewidth = 0.7)+
scale_colour_manual(values = c("GRB" = "#2166ac", "PB" = "#d6604d")) +
scale_shape_manual(values  = c("GRB" = 16, "PB" = 17)) +
labs(
title    = "PCA of ICP-MS Trace Elements",
subtitle = "Log-transformed, centred & scaled | 90% confidence ellipses",
x        = paste0("PC1 (", var_explained[1], "% variance)"),
y        = paste0("PC2 (", var_explained[2], "% variance)"),
colour   = "Formation", shape = "Formation"
) +
theme_bw(base_size = 12) +
theme(legend.position = "bottom")
print(pca_plot)
pca_plot <- ggplot(ind_coords, aes(x = Dim.1, y = Dim.2, colour = Group, shape = Group)) +
geom_point(size = 3, alpha = 0.85) +
geom_hline(yintercept = 0, linetype = "dashed", colour = "grey60") +
geom_vline(xintercept = 0, linetype = "dashed", colour = "grey60") +
stat_ellipse(aes(group = Group), type = "norm", level = 0.90, linetype = "solid", linewidth = 0.7)+
scale_colour_manual(values = c("GRB" = "#2166ac", "PB" = "#d6604d")) +
scale_shape_manual(values  = c("GRB" = 16, "PB" = 17)) +
labs(
title    = "PCA of ICP-MS Trace Elements",
subtitle = "Log-transformed, centred & scaled | 90% confidence ellipses",
x        = paste0("PC1 (", var_explained[1], "% variance)"),
y        = paste0("PC2 (", var_explained[2], "% variance)"),
colour   = "Formation", shape = "Formation"
) +
theme_bw(base_size = 12) +
theme(legend.position = "bottom")
print(pca_plot)
ggsave("pca_plot.png", pca_plot, width = 9, height = 5, dpi = 300)
ratio_labels <- c(
La_Yb  = "La/Yb  (Partial Melting)",
Eu_anom = "Eu/Eu*  (Eu Anomaly)",
Sc_Zr  = "Sc/Zr  (Cpx + Plag Fractionation)",
Ba_Nb  = "Ba/Nb  (Crustal Assimilation)",
La_Nb  = "La/Nb  (Crustal Assimilation)"
)
df_long <- df %>%
select(Group, all_of(ratios)) %>%
pivot_longer(cols = all_of(ratios), names_to = "Ratio", values_to = "Value") %>%
mutate(Ratio = factor(Ratio, levels = ratios,
labels = ratio_labels[ratios]))
box_plot <- ggplot(df_long, aes(x = Group, y = Value, fill = Group)) +
geom_boxplot(outlier.shape = 21, alpha = 0.7, width = 0.5) +
geom_jitter(width = 0.12, size = 1.5, alpha = 0.6, colour = "grey30") +
facet_wrap(~Ratio, scales = "free_y", ncol = 3) +
scale_fill_manual(values = c("GRB" = "#2166ac", "PB" = "#d6604d")) +
labs(
title = "Diagnostic Geochemical Ratios: GRB vs. PB",
x = NULL, y = "Ratio Value"
) +
theme_bw(base_size = 11) +
theme(legend.position = "none",
strip.background = element_rect(fill = "grey90"))
ggsave("box_plot.png", box_plot, width = 9, height = 5, dpi = 300)
print(box_plot)
# =============================================================================
# 7. RAYLEIGH FRACTIONAL CRYSTALLIZATION MODEL (Sc–Zr)
# =============================================================================
# This section fits a power-law trend: Zr = a * Sc^b  (log-log linear)
cat("\n=== Fractional Crystallization Model: log(Zr) ~ log(Sc) ===\n")
#Extract the Fractional Crystallization Data
fc_data <- df %>% select(Group, Sc, Zr) %>% drop_na() %>%
mutate(log_Sc = log(Sc), log_Zr = log(Zr))
# Fit separate regressions per group
fc_models <- fc_data %>%
group_by(Group) %>%
group_map(~ {
m <- lm(log_Zr ~ log_Sc, data = .x)
tibble(
Group     = .y$Group,
Intercept = round(coef(m)[1], 3),
Slope     = round(coef(m)[2], 3),
R2        = round(summary(m)$r.squared, 3),
p_slope   = round(summary(m)$coefficients[2, 4], 4)
)
}) %>%
bind_rows()
print(fc_models)
fc_plot <- ggplot(fc_data, aes(x = Sc, y = Zr, colour = Group, shape = Group)) +
geom_point(size = 3, alpha = 0.8) +
geom_smooth(method = "lm", formula = y ~ x, se = TRUE, alpha = 0.15) +
scale_x_log10() + scale_y_log10() +
scale_colour_manual(values = c("GRB" = "#2166ac", "PB" = "#d6604d")) +
scale_shape_manual(values  = c("GRB" = 16, "PB" = 17)) +
annotation_logticks(sides = "bl") +
labs(
title    = "Fractional Crystallization Trend: Sc vs. Zr",
subtitle = "Log–log scale | Compatible (Sc) vs. Incompatible (Zr)",
x = "Sc (ppm)", y = "Zr (ppm)",
colour = "Formation", shape = "Formation"
) +
theme_bw(base_size = 12) +
theme(legend.position = "bottom")
ggsave("fc_plot.png", fc_plot, width = 9, height = 5, dpi = 300)
print(fc_plot)
# --- Also fit Yb–La ----------------------------------------------------------
cat("\n=== Fractional Crystallization Model: log(La) ~ log(Yb) ===\n")
la_yb_data <- df %>% select(Group, La, Yb) %>% drop_na() %>%
mutate(log_La = log(La), log_Yb = log(Yb))
la_yb_models <- la_yb_data %>%
group_by(Group) %>%
group_map(~ {
m <- lm(log_La ~ log_Yb, data = .x)
tibble(
Group     = .y$Group,
Intercept = round(coef(m)[1], 3),
Slope     = round(coef(m)[2], 3),
R2        = round(summary(m)$r.squared, 3),
p_slope   = round(summary(m)$coefficients[2, 4], 4)
)
}) %>%
bind_rows()
print(la_yb_models)
la_yb_plot <- ggplot(la_yb_data, aes(x = Yb, y = La, colour = Group, shape = Group)) +
geom_point(size = 3, alpha = 0.8) +
geom_smooth(method = "lm", se = TRUE, alpha = 0.15) +
scale_colour_manual(values = c("GRB" = "#2166ac", "PB" = "#d6604d")) +
scale_shape_manual(values  = c("GRB" = 16, "PB" = 17)) +
labs(
title    = "La vs. Yb: REE Fractionation Trend",
subtitle = "LREE enrichment relative to HREE",
x = "Yb (ppm)", y = "La (ppm)",
colour = "Formation", shape = "Formation"
) +
theme_bw(base_size = 12) +
theme(legend.position = "bottom")
print(la_yb_plot)
ggsave("la_yb_diagram.png", la_yb_plot, width = 9, height = 5, dpi = 300)
